# Confluence 连接配置示例
# 复制此文件为 .env 并填写您的实际配置
# 
# 注意：.env 文件包含敏感信息，请勿提交到版本控制系统

# Confluence 服务器地址
CONFLUENCE_URL=https://your-confluence-domain.com/

# 认证信息（使用用户名和密码）
CONFLUENCE_USERNAME=your_username
CONFLUENCE_PASSWORD=your_password

# 是否为 Confluence Cloud 版本
# true: Cloud 版本 (cloud.atlassian.com)
# false: Server/Data Center 版本（自建）
CONFLUENCE_CLOUD=false

# 是否验证 SSL 证书
# true: 生产环境建议开启
# false: 内网/测试环境可关闭（跳过证书验证）
CONFLUENCE_VERIFY_SSL=false

# 测试配置（用于test_client.py中的测试）
# TEST_PAGE_ID=28381118
# TEST_SPACE=app
# TEST_TITLE=需求方案
# TEST_CQL=space = "app"
# TEST_PARENT_ID=12345
